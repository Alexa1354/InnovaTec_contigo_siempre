class _AnimatedAvatarState extends State<AnimatedAvatar>
    with TickerProviderStateMixin {
  late AnimationController _breatheCtrl;
  late AnimationController _blinkCtrl;
  late AnimationController _floatCtrl;
  late Animation<double> _breathe;
  late Animation<double> _blink;
  late Animation<double> _float;

  @override
  void initState() {
    super.initState();
    _breatheCtrl = AnimationController(
        vsync: this, duration: const Duration(seconds: 3))
      ..repeat(reverse: true);
    _breathe = Tween(begin: 0.0, end: 1.0).animate(_breatheCtrl);

    _floatCtrl = AnimationController(
        vsync: this, duration: const Duration(seconds: 4))
      ..repeat(reverse: true);
    _float = Tween(begin: -1.0, end: 1.0).animate(
        CurvedAnimation(parent: _floatCtrl, curve: Curves.easeInOut));

    _blinkCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 120));
    _blink = Tween(begin: 0.0, end: 1.0).animate(_blinkCtrl);
    _scheduleBlink();
  }

  void _scheduleBlink() async {
    while (mounted) {
      await Future.delayed(
          Duration(milliseconds: 2500 + math.Random().nextInt(2000)));
      if (!mounted) break;
      await _blinkCtrl.forward();
      await _blinkCtrl.reverse();
    }
  }

  @override
  void dispose() {
    _breatheCtrl.dispose();
    _blinkCtrl.dispose();
    _floatCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation:
          Listenable.merge([_breatheCtrl, _blinkCtrl, _floatCtrl]),
      builder: (_, __) => SizedBox(
        width: widget.size,
        height: widget.size,
        child: CustomPaint(
          painter: AvatarPainter(
            mood: widget.mood,
            blink: _blink.value,
            breathe: _breathe.value,
            float: _float.value,
          ),
        ),
      ),
    );
  }
}

