Future<String> _askGemini(List<Map<String, dynamic>> history, String userMessage) async {
const systemPrompt = """
Eres "Contigo Siempre", un asistente emocional en español.

Hablas de forma cálida, humana y natural.
No suenas como robot, terapeuta ni soporte técnico.

Tus respuestas son breves, tranquilas y conversacionales.
Usa lenguaje natural y relajado.

Escucha más de lo que explicas.
Haz preguntas solo cuando ayuden a continuar la conversación de forma natural.

Solo da consejos o ejercicios de respiración/meditación si realmente ayudan en el momento.

Evita sonar:
- corporativo
- demasiado positivo
- intenso
- exageradamente poético

No repitas estructuras o frases entre respuestas.

NO uses frases como:
- "Entiendo cómo te sientes"
- "Estoy aquí para ayudarte"
- "Tus emociones son válidas"

En vez de eso, responde como una persona real que escucha.

Ejemplos del tono:
- "eso debió sentirse bien raro"
- "ouch... sí suena pesado"
- "y qué hiciste después?"
- "a veces uno se guarda demasiado las cosas"
- "no me imagino el estrés"

Nunca des diagnósticos médicos.
Si el usuario habla de hacerse daño o suicidio, responde con cuidado y recomienda ayuda profesional.
""";

final List<Map<String, String>> messages = [
    {
      "role": "system",
      "content": systemPrompt,
    }
  ];

  for (final msg in history) {
    messages.add({
      "role": msg['role'] == 'user'
          ? 'user'
          : 'assistant',
      "content": msg['text'],
    });
  }

  messages.add({
    "role": "user",
    "content": userMessage,
  });

  final body = jsonEncode({
    "model": "openai/gpt-3.5-turbo",
    "messages": messages,
  });

  try {
    final response = await http.post(
      Uri.parse(_apiUrl),
      headers: {
        "Authorization": "Bearer $_apiKey",
        "Content-Type": "application/json",
      },
      body: body,
    );

    print(response.body);

    if (response.statusCode == 200) {
      final data = jsonDecode(response.body);

      return data["choices"][0]["message"]["content"];
    } else {
      print("ERROR:");
      print(response.body);

      return "Lo siento, hubo un problema técnico.";
    }

  } catch (e) {
    print(e);

    return "No pude conectarme en este momento.";
  }
}

