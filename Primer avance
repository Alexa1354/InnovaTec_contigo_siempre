// ─── Floating Draggable Mini Avatar ──────────────────────────────────────────
class FloatingMiniAvatar extends StatefulWidget {
  final String mood;
  const FloatingMiniAvatar({super.key, required this.mood});

  @override
  State<FloatingMiniAvatar> createState() => _FloatingMiniAvatarState();
}

class _FloatingMiniAvatarState extends State<FloatingMiniAvatar>
    with TickerProviderStateMixin {
  // Position on screen — starts bottom-left, set properly on first layout
  double _x = 16;
  double _y = -1; // -1 = not initialized yet
  bool _isDragging = false;

  // Idle float animation (pauses while dragging)
  late AnimationController _floatCtrl;
  late Animation<double> _floatY;

  // Wiggle on release
  late AnimationController _wiggleCtrl;
  late Animation<double> _wiggle;

  // Scale pop on grab
  late AnimationController _scaleCtrl;
  late Animation<double> _scale;

  static const double _avatarSize = 56;

  @override
  void initState() {
    super.initState();

    _floatCtrl = AnimationController(
        vsync: this, duration: const Duration(seconds: 3))
      ..repeat(reverse: true);
    _floatY = Tween(begin: 0.0, end: -8.0)
        .animate(CurvedAnimation(parent: _floatCtrl, curve: Curves.easeInOut));

    _wiggleCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 400));
    _wiggle = Tween(begin: -0.12, end: 0.12).animate(
        CurvedAnimation(parent: _wiggleCtrl, curve: Curves.elasticIn));

    _scaleCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 150));
    _scale = Tween(begin: 1.0, end: 1.18)
        .animate(CurvedAnimation(parent: _scaleCtrl, curve: Curves.easeOut));
  }

  @override
  void dispose() {
    _floatCtrl.dispose();
    _wiggleCtrl.dispose();
    _scaleCtrl.dispose();
    super.dispose();
  }

  Color _moodColor(String m) {
    switch (m) {
      case 'happy': return kAmber;
      case 'sad': return const Color(0xFF74B9FF);
      case 'anxious': return kPink;
      case 'crisis': return kCrisisRed;
      default: return kAccent;
    }
  }

  void _onPanStart(DragStartDetails d, BoxConstraints constraints) {
    setState(() => _isDragging = true);
    _floatCtrl.stop();
    _scaleCtrl.forward();
  }

  void _onPanUpdate(DragUpdateDetails d, BoxConstraints constraints) {
    setState(() {
      _x = (_x + d.delta.dx).clamp(0, constraints.maxWidth - _avatarSize);
      _y = (_y + d.delta.dy).clamp(0, constraints.maxHeight - _avatarSize);
    });
  }

  void _onPanEnd(DragEndDetails d, BoxConstraints constraints) {
    setState(() => _isDragging = false);
    _scaleCtrl.reverse();
    _floatCtrl.repeat(reverse: true);
    // Wiggle on drop
    wiggleCtrl.forward(from: 0).then(() => _wiggleCtrl.reverse());
  }

  @override
  Widget build(BuildContext context) {
    return LayoutBuilder(builder: (context, constraints) {
      // Initialize Y to bottom-left on first build
      if (_y < 0) _y = constraints.maxHeight - _avatarSize - 8;

      return SizedBox.expand(
        child: AnimatedBuilder(
          animation: Listenable.merge([_floatCtrl, _wiggleCtrl, _scaleCtrl]),
          builder: (, _) {
            final floatOffset = _isDragging ? 0.0 : _floatY.value;
            final wiggleAngle = _isDragging ? 0.0 : _wiggle.value * (1 - _wiggleCtrl.value);

            return Stack(
              children: [
                Positioned(
                  left: _x,
                  top: _y + floatOffset,
                  child: GestureDetector(
                    onPanStart: (d) => _onPanStart(d, constraints),
                    onPanUpdate: (d) => _onPanUpdate(d, constraints),
                    onPanEnd: (d) => _onPanEnd(d, constraints),
                    child: Transform.scale(
                      scale: _scale.value,
                      child: Transform.rotate(
                        angle: wiggleAngle,
                        child: Container(
                          width: _avatarSize,
                          height: _avatarSize,
                          decoration: BoxDecoration(
                            shape: BoxShape.circle,
                            color: kCard,
                            border: Border.all(
                              color: _isDragging
                                  ? _moodColor(widget.mood)
                                  : kBorder,
                              width: _isDragging ? 2 : 1.5,
                            ),
                            boxShadow: [
                              BoxShadow(
                                color: _moodColor(widget.mood)
                                    .withOpacity(_isDragging ? 0.55 : 0.28),
                                blurRadius: _isDragging ? 22 : 14,
                                spreadRadius: _isDragging ? 3 : 1,
                              ),
                            ],
                          ),
                          child: AnimatedAvatar(mood: widget.mood, size: _avatarSize),
                        ),
                      ),
                    ),
                  ),
                ),
              ],
            );
          },
        ),
      );
    });
  }
}

// ─── Chat Screen ──────────────────────────────────────────────────────────────
class ChatScreen extends StatefulWidget {
  final VoidCallback? onMoodChange;
  const ChatScreen({super.key, this.onMoodChange});

  @override
  State<ChatScreen> createState() => _ChatScreenState();
}

class _ChatScreenState extends State<ChatScreen> {
  final List<Map<String, dynamic>> _messages = [];
  final TextEditingController _controller = TextEditingController();
  final ScrollController _scroll = ScrollController();
  bool _showCrisis = false;

  void _send() {
    final text = _controller.text.trim();
    if (text.isEmpty) return;

    final isCrisis = _isCrisisMessage(text);
    final oldMood = mood;

    setState(() {
      _messages.add({'role': 'user', 'text': text});
      sessionCount++;

      final lower = text.toLowerCase();
      if (isCrisis) {
        mood = 'crisis';
        _showCrisis = true;
        _messages.add({'role': 'aura', 'text': _crisisReply()});
      } else if (lower.contains('normal') || lower.contains('más o menos') ||
          lower.contains('mas o menos') || lower.contains('regular')) {
        mood = 'neutral';
        _messages.add({'role': 'aura', 'text': _auraReply(mood)});
      } else if (lower.contains('triste') || lower.contains('llorar') ||
          lower.contains('deprim') || lower.contains('mal')) {
        mood = 'sad';
        _messages.add({'role': 'aura', 'text': _auraReply(mood)});
      } else if (lower.contains('feliz') || lower.contains('bien') ||
          lower.contains('genial') || lower.contains('contento') ||
          lower.contains('alegre')) {
        mood = 'happy';
        _messages.add({'role': 'aura', 'text': _auraReply(mood)});
      } else if (lower.contains('ansios') || lower.contains('estresad') ||
          lower.contains('nervios') || lower.contains('preocup')) {
        mood = 'anxious';
        _messages.add({'role': 'aura', 'text': _auraReply(mood)});
      } else {
        _messages.add({'role': 'aura', 'text': _auraReply(mood)});
      }

      if (mood != oldMood) widget.onMoodChange?.call();
    });

    _controller.clear();
    Future.delayed(const Duration(milliseconds: 150), () {
      if (_scroll.hasClients) {
        _scroll.animateTo(_scroll.position.maxScrollExtent,
            duration: const Duration(milliseconds: 300), curve: Curves.easeOut);
      }
    });
  }

  String _auraReply(String m) {
    switch (m) {
      case 'sad': return 'Estoy aquí contigo. Está bien sentirse así. ¿Quieres contarme qué pasó?';
      case 'happy': return '¡Qué bien escuchar eso! Ese estado de ánimo es un tesoro. ¿Qué te hizo sentir así hoy?';
      case 'anxious': return 'Toma un respiro. Inspira... y exhala. Cuéntame qué te tiene con esa energía.';
      default: return 'Gracias por compartir. ¿Cómo te ha ido el resto del día?';
    }
  }

  String _crisisReply() =>
      'Gracias por confiarme esto. Lo que sientes es real y merece atención. '
      'Por favor, habla con alguien ahora — hay una línea de ayuda disponible para ti. 💜';

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: kBg,
      appBar: AppBar(
        backgroundColor: kSurface,
        elevation: 0,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios, color: kTextPrimary, size: 18),
          onPressed: () => Navigator.pop(context),
        ),
        title: Row(children: [
          AnimatedAvatar(mood: mood, size: 36),
          const SizedBox(width: 10),
          Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            const Text('Contigo Siempre', style: TextStyle(
                color: kTextPrimary, fontSize: 15, fontWeight: FontWeight.w600)),
            Row(children: [
              Container(width: 7, height: 7,
                  decoration: const BoxDecoration(color: kTeal, shape: BoxShape.circle)),
              const SizedBox(width: 4),
              const Text('en línea', style: TextStyle(color: kTeal, fontSize: 11)),
            ]),
          ]),
        ]),
        bottom: PreferredSize(
          preferredSize: const Size.fromHeight(1),
          child: Container(height: 1, color: kBorder),
        ),
      ),
      body: Stack(
        children: [
          Column(
            children: [
              // Messages list
              Expanded(
                child: ListView.builder(
                  controller: _scroll,
                  padding: const EdgeInsets.fromLTRB(16, 16, 16, 8),
                  itemCount: _messages.isEmpty ? 1 : _messages.length,
                  itemBuilder: (_, i) {
                    if (_messages.isEmpty) return _emptyState();
                    final msg = _messages[i];
                    final isUser = msg['role'] == 'user';
                    return _MessageBubble(text: msg['text']!, isUser: isUser, mood: mood);
                  },
                ),
              ),

              // Crisis banner
              if (_showCrisis) CrisisBanner(key: ValueKey(_showCrisis)),

              // Input area
              Container(
                padding: const EdgeInsets.fromLTRB(16, 12, 16, 20),
                decoration: BoxDecoration(
                  color: kSurface,
                  border: Border(top: BorderSide(color: kBorder, width: 1)),
                ),
                child: Row(children: [
                  Expanded(child: AppTextField(controller: _controller, hint: 'Cuéntame algo...')),
                  const SizedBox(width: 10),
                  GestureDetector(
                    onTap: _send,
                    child: Container(
                      width: 50, height: 50,
                      decoration: BoxDecoration(
                        color: kAccent, borderRadius: BorderRadius.circular(14),
                        boxShadow: [BoxShadow(color: kAccent.withOpacity(0.4), blurRadius: 16, offset: const Offset(0, 4))],
                      ),
                      child: const Icon(Icons.send_rounded, color: Colors.white, size: 20),
                    ),
                  ),
                ]),
              ),
            ],
          ),

          // ── Floating draggable mini avatar (fills stack so it can go anywhere)
          Positioned.fill(
            // Leave room at the bottom for the input bar
