              const SizedBox(height: 28),
              const Text('Esta semana', style: TextStyle(
                  fontSize: 13, color: kTextSecondary, letterSpacing: 1.5, fontWeight: FontWeight.w500)),
              const SizedBox(height: 12),
              _WeekGrid(),
              const SizedBox(height: 32),
            ],
          ),
        ),
      ),
    );
  }
}

class _ProgressCard extends StatelessWidget {
  final String icon;
  final String label;
  final String value;
  const _ProgressCard({required this.icon, required this.label, required this.value});

  @override
  Widget build(BuildContext context) {
    return Container(
      margin: const EdgeInsets.only(bottom: 10),
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: kCard, borderRadius: BorderRadius.circular(16),
        border: Border.all(color: kBorder, width: 1),
      ),
      child: Row(children: [
        Text(icon, style: const TextStyle(fontSize: 24)),
        const SizedBox(width: 14),
        Text(label, style: const TextStyle(color: kTextSecondary, fontSize: 14)),
        const Spacer(),
        Text(value, style: const TextStyle(color: kTextPrimary, fontSize: 15, fontWeight: FontWeight.w600)),
      ]),
    );
  }
}

class _WeekGrid extends StatelessWidget {
  final List<String> days = const ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
  final List<bool> completed = const [true, true, true, false, false, false, false];

  @override
  Widget build(BuildContext context) {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: List.generate(7, (i) {
        final done = completed[i];
        return Column(children: [
          Container(
            width: 38, height: 38,
            decoration: BoxDecoration(
              color: done ? kAccent.withOpacity(0.2) : kCard,
              borderRadius: BorderRadius.circular(10),
              border: Border.all(color: done ? kAccent : kBorder, width: done ? 1.5 : 1),
            ),
            child: done ? const Icon(Icons.check_rounded, color: kAccentLight, size: 18) : null,
          ),
          const SizedBox(height: 6),
          Text(days[i], style: TextStyle(
            fontSize: 10,
            color: done ? kAccentLight : kTextSecondary,
            fontWeight: done ? FontWeight.w600 : FontWeight.w400,
          )),
        ]);
      }),
    );
  }
}
