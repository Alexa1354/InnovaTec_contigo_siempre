// ─── Flower Painter (Welcome Screen icon) ────────────────────────────────────
class FlowerPainter extends CustomPainter {
  final double openAmount;   // 0.0 = closed bud → 1.0 = fully open
  final double rotateAnim;   // slow rotation
  final double glowPulse;    // pulse for the glow

  FlowerPainter({required this.openAmount, required this.rotateAnim, required this.glowPulse});

  @override
  void paint(Canvas canvas, Size size) {
    // Clamp to [0,1] — elasticOut can briefly go negative or above 1
    final t = openAmount.clamp(0.0, 1.0);

    final cx = size.width / 2;
    final cy = size.height / 2;

    canvas.save();
    canvas.translate(cx, cy);
    canvas.rotate(rotateAnim * 2 * math.pi * 0.04);
    canvas.translate(-cx, -cy);

    // ── Glow
    final glowPaint = Paint()
      ..color = kAccent.withOpacity(0.10 + glowPulse * 0.08)
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 28);
    canvas.drawCircle(Offset(cx, cy), 60 + glowPulse * 10, glowPaint);

    // ── Petals — 6 petals that open outward
    final int petalCount = 6;
    for (int i = 0; i < petalCount; i++) {
      final angle = (i / petalCount) * 2 * math.pi;
      final petalLength = (28.0 + t * 28.0).clamp(1.0, double.infinity);
      final petalWidth  = (10.0 + t * 10.0).clamp(1.0, double.infinity);
      final dist = 16.0 + t * 20.0;

      final petalPx = cx + math.cos(angle) * dist;
      final petalPy = cy + math.sin(angle) * dist;

      // Color shifts with open amount
      final Color petalColor = Color.lerp(
        const Color(0xFF9B8FF5),
        i % 2 == 0 ? kPink : kAccentLight,
        t,
      )!;

      final paint = Paint()..color = petalColor.withOpacity((0.85 + t * 0.15).clamp(0.0, 1.0));

      canvas.save();
      canvas.translate(petalPx, petalPy);
      canvas.rotate(angle + math.pi / 2);
      canvas.drawOval(
        Rect.fromCenter(
          center: Offset(0, petalLength / 2),
          width: petalWidth,
          height: petalLength,
        ),
        paint,
      );
      canvas.restore();
    }

    // ── Inner petals (smaller, rotate offset)
    for (int i = 0; i < petalCount; i++) {
      final angle = (i / petalCount) * 2 * math.pi + math.pi / petalCount;
      final petalLength = (16.0 + t * 18.0).clamp(1.0, double.infinity);
      final petalWidth  = (7.0  + t * 6.0).clamp(1.0, double.infinity);
      final dist = 10.0 + t * 12.0;

      final petalPx = cx + math.cos(angle) * dist;
      final petalPy = cy + math.sin(angle) * dist;

      final paint = Paint()..color = kTeal.withOpacity((0.6 + t * 0.3).clamp(0.0, 1.0));

      canvas.save();
      canvas.translate(petalPx, petalPy);
      canvas.rotate(angle + math.pi / 2);
      canvas.drawOval(
        Rect.fromCenter(
          center: Offset(0, petalLength / 2),
          width: petalWidth,
          height: petalLength,
        ),
        paint,
      );
      canvas.restore();
    }

    // ── Center
    final centerColor = Color.lerp(kAccent, kAmber, t)!;
    final centerPaint = Paint()..color = centerColor;
    canvas.drawCircle(Offset(cx, cy), 12 + t * 6, centerPaint);

    // ── Center shimmer dots
    final dotPaint = Paint()..color = Colors.white.withOpacity(0.6);
    for (int i = 0; i < 5; i++) {
      final a = (i / 5) * 2 * math.pi;
      canvas.drawCircle(
        Offset(cx + math.cos(a) * 6, cy + math.sin(a) * 6),
        1.5, dotPaint,
      );
    }

    canvas.restore();
  }

  @override
  bool shouldRepaint(FlowerPainter old) =>
      old.openAmount != openAmount || old.rotateAnim != rotateAnim || old.glowPulse != glowPulse;
}

class AnimatedFlower extends StatefulWidget {
  final double size;
  final bool blooming; // triggers the bloom animation

  const AnimatedFlower({super.key, this.size = 140, this.blooming = false});

  @override
  State<AnimatedFlower> createState() => _AnimatedFlowerState();
}

class _AnimatedFlowerState extends State<AnimatedFlower>
    with TickerProviderStateMixin {
  late AnimationController _bloomCtrl;
  late AnimationController _rotCtrl;
  late AnimationController _pulseCtrl;
  late Animation<double> _bloom;
  late Animation<double> _pulse;

  @override
  void initState() {
    super.initState();
    _bloomCtrl = AnimationController(vsync: this, duration: const Duration(milliseconds: 700));
    _bloom = CurvedAnimation(parent: _bloomCtrl, curve: Curves.easeOutBack);

    _rotCtrl = AnimationController(vsync: this, duration: const Duration(seconds: 20))..repeat();

    _pulseCtrl = AnimationController(vsync: this, duration: const Duration(seconds: 2))
      ..repeat(reverse: true);
    _pulse = Tween(begin: 0.0, end: 1.0).animate(
        CurvedAnimation(parent: _pulseCtrl, curve: Curves.easeInOut));
  }

  @override
  void didUpdateWidget(AnimatedFlower old) {
    super.didUpdateWidget(old);
    if (widget.blooming && !old.blooming) {
      _bloomCtrl.forward(from: 0);
    }
  }

  @override
  void dispose() {
    _bloomCtrl.dispose();
    _rotCtrl.dispose();
    _pulseCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: Listenable.merge([_bloomCtrl, _rotCtrl, _pulseCtrl]),
      builder: (, _) => SizedBox(
        width: widget.size,
        height: widget.size,
        child: CustomPaint(
          painter: FlowerPainter(
            openAmount: _bloom.value,
            rotateAnim: _rotCtrl.value,
            glowPulse: _pulse.value,
          ),
        ),
      ),
    );
  }
}

// ─── Avatar Painter ──────────────────────────────────────────────────────────
class AvatarPainter extends CustomPainter {
  final String mood;
  final double blink;
  final double breathe;
  final double float;

  AvatarPainter({required this.mood, required this.blink, required this.breathe, required this.float});

  Color get faceColor {
    switch (mood) {
      case 'happy': return const Color(0xFFFFD166);
      case 'sad': return const Color(0xFF74B9FF);
      case 'anxious': return const Color(0xFFFF7675);
      case 'crisis': return const Color(0xFFB983FF); // pale purple — shocked
      default: return const Color(0xFF81ECEC);
    }
  }

  Color get cheekColor {
    switch (mood) {
      case 'happy': return const Color(0xFFFF6B9D).withOpacity(0.5);
      case 'sad': return const Color(0xFF74B9FF).withOpacity(0.3);
      case 'anxious': return const Color(0xFFFF7675).withOpacity(0.4);
      case 'crisis': return const Color(0xFFFF3B3B).withOpacity(0.25);
      default: return const Color(0xFFA29BFE).withOpacity(0.3);
    }
  }

  @override
  void paint(Canvas canvas, Size size) {
    final cx = size.width / 2;
    final cy = size.height / 2 + float * 4;
    final scale = 1.0 + breathe * 0.02;
    final radius = (size.width / 2 - 8) * scale;

    canvas.save();
    canvas.translate(cx, cy);
    canvas.scale(scale, scale);
    canvas.translate(-cx, -cy);

    // Glow
    final glowPaint = Paint()
      ..color = faceColor.withOpacity(0.2)
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 12);
    canvas.drawCircle(Offset(cx, cy), radius + 6, glowPaint);

    // Face
    canvas.drawCircle(Offset(cx, cy), radius, Paint()..color = faceColor);

    // Cheeks
    canvas.drawCircle(Offset(cx - radius * 0.52, cy + radius * 0.2),
        radius * 0.26, Paint()..color = cheekColor);
    canvas.drawCircle(Offset(cx + radius * 0.52, cy + radius * 0.2),
        radius * 0.26, Paint()..color = cheekColor);

    // Eyes — crisis = huge wide open
    final eyeH = mood == 'crisis'
        ? radius * 0.30
        : (blink < 0.8 ? radius * 0.20 : (1.0 - blink) * radius * 0.25);
    final eyeW = mood == 'crisis' ? radius * 0.22 : radius * 0.13;
    final eyePaint = Paint()..color = Colors.white;
    final pupilPaint = Paint()..color = const Color(0xFF2D3436);

    canvas.drawOval(
      Rect.fromCenter(center: Offset(cx - radius * 0.30, cy - radius * 0.12),
          width: eyeW * 2, height: eyeH * 2), eyePaint);
    canvas.drawCircle(Offset(cx - radius * 0.30, cy - radius * 0.12 + eyeH * 0.1),
        eyeH * 0.55, pupilPaint);

    canvas.drawOval(
      Rect.fromCenter(center: Offset(cx + radius * 0.30, cy - radius * 0.12),
          width: eyeW * 2, height: eyeH * 2), eyePaint);
    canvas.drawCircle(Offset(cx + radius * 0.30, cy - radius * 0.12 + eyeH * 0.1),
        eyeH * 0.55, pupilPaint);

    // Mouth
    final mouthPaint = Paint()
      ..color = const Color(0xFF2D3436)
      ..style = PaintingStyle.stroke
      ..strokeWidth = radius * 0.035
      ..strokeCap = StrokeCap.round;
    final path = Path();
    switch (mood) {
      case 'happy':
        path.moveTo(cx - radius * 0.30, cy + radius * 0.28);
        path.cubicTo(cx - radius * 0.14, cy + radius * 0.50,
            cx + radius * 0.14, cy + radius * 0.50, cx + radius * 0.30, cy + radius * 0.28);
        break;
      case 'sad':
        path.moveTo(cx - radius * 0.30, cy + radius * 0.46);
        path.cubicTo(cx - radius * 0.14, cy + radius * 0.28,
            cx + radius * 0.14, cy + radius * 0.28, cx + radius * 0.30, cy + radius * 0.46);
        break;
      case 'anxious':
        path.moveTo(cx - radius * 0.28, cy + radius * 0.36);
        path.lineTo(cx - radius * 0.10, cy + radius * 0.42);
        path.lineTo(cx + radius * 0.10, cy + radius * 0.32);
        path.lineTo(cx + radius * 0.28, cy + radius * 0.38);
        break;
      case 'crisis':
        // Open "O" mouth — drawn as a filled oval outline
        canvas.drawOval(
          Rect.fromCenter(
            center: Offset(cx, cy + radius * 0.40),
            width: radius * 0.30,
            height: radius * 0.22,
          ),
          mouthPaint,
        );
        break;
      default:
        path.moveTo(cx - radius * 0.26, cy + radius * 0.38);
        path.lineTo(cx + radius * 0.26, cy + radius * 0.38);
    }
    if (mood != 'crisis') canvas.drawPath(path, mouthPaint);

    // Eyebrows
    final browPaint = Paint()
      ..color = const Color(0xFF2D3436).withOpacity(0.7)
      ..style = PaintingStyle.stroke
      ..strokeWidth = radius * 0.035
      ..strokeCap = StrokeCap.round;

    if (mood == 'crisis') {
      // Very high arched brows — pure shock/concern
      final browPath = Path();
      browPath.moveTo(cx - radius * 0.44, cy - radius * 0.52);
      browPath.cubicTo(cx - radius * 0.30, cy - radius * 0.62,
          cx - radius * 0.16, cy - radius * 0.60, cx - radius * 0.10, cy - radius * 0.50);
      canvas.drawPath(browPath, browPaint);
      final browPath2 = Path();
      browPath2.moveTo(cx + radius * 0.10, cy - radius * 0.50);
      browPath2.cubicTo(cx + radius * 0.16, cy - radius * 0.60,
          cx + radius * 0.30, cy - radius * 0.62, cx + radius * 0.44, cy - radius * 0.52);
      canvas.drawPath(browPath2, browPaint);
    } else if (mood == 'anxious') {
      canvas.drawLine(Offset(cx - radius * 0.42, cy - radius * 0.40),
          Offset(cx - radius * 0.18, cy - radius * 0.34), browPaint);
      canvas.drawLine(Offset(cx + radius * 0.18, cy - radius * 0.34),
          Offset(cx + radius * 0.42, cy - radius * 0.40), browPaint);
    } else if (mood == 'sad') {
      canvas.drawLine(Offset(cx - radius * 0.42, cy - radius * 0.34),
          Offset(cx - radius * 0.18, cy - radius * 0.42), browPaint);
      canvas.drawLine(Offset(cx + radius * 0.18, cy - radius * 0.42),
          Offset(cx + radius * 0.42, cy - radius * 0.34), browPaint);
    } else {
      final browY = mood == 'happy' ? cy - radius * 0.44 : cy - radius * 0.38;
      canvas.drawLine(Offset(cx - radius * 0.42, browY),
          Offset(cx - radius * 0.18, browY), browPaint);
      canvas.drawLine(Offset(cx + radius * 0.18, browY),
          Offset(cx + radius * 0.42, browY), browPaint);
    }

    canvas.restore();
  }

  @override
  bool shouldRepaint(AvatarPainter old) =>
      old.mood != mood || old.blink != blink || old.breathe != breathe || old.float != float;
}

// ─── Animated Avatar Widget ───────────────────────────────────────────────────
class AnimatedAvatar extends StatefulWidget {
  final String mood;
  final double size;
  const AnimatedAvatar({super.key, required this.mood, this.size = 160});

  @override
  State<AnimatedAvatar> createState() => _AnimatedAvatarState();
}

class _AnimatedAvatarState extends State<AnimatedAvatar>
    with TickerProviderStateMixin {
  late AnimationController _breatheCtrl;
  late AnimationController _blinkCtrl;
  late AnimationController _floatCtrl;
  late Animation<double> _breathe;
  late Animation<double> _blink;
  late Animation<double> _float;

  @override
  void initState() {
    super.initState();
    _breatheCtrl = AnimationController(vsync: this, duration: const Duration(seconds: 3))
      ..repeat(reverse: true);
    _breathe = Tween(begin: 0.0, end: 1.0).animate(_breatheCtrl);

    _floatCtrl = AnimationController(vsync: this, duration: const Duration(seconds: 4))
      ..repeat(reverse: true);
    _float = Tween(begin: -1.0, end: 1.0)
        .animate(CurvedAnimation(parent: _floatCtrl, curve: Curves.easeInOut));

    _blinkCtrl = AnimationController(vsync: this, duration: const Duration(milliseconds: 120));
    _blink = Tween(begin: 0.0, end: 1.0).animate(_blinkCtrl);
    _scheduleBlink();
  }

  void _scheduleBlink() async {
    while (mounted) {
      await Future.delayed(Duration(milliseconds: 2500 + math.Random().nextInt(2000)));
      if (!mounted) break;
      await _blinkCtrl.forward();
      await _blinkCtrl.reverse();
    }
  }

  @override
  void dispose() {
    _breatheCtrl.dispose();
    _blinkCtrl.dispose();
    _floatCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: Listenable.merge([_breatheCtrl, _blinkCtrl, _floatCtrl]),
      builder: (, _) => SizedBox(
        width: widget.size,
        height: widget.size,
        child: CustomPaint(
          painter: AvatarPainter(
            mood: widget.mood,
            blink: _blink.value,
            breathe: _breathe.value,
            float: _float.value,
          ),
        ),
      ),
    );
  }
}

