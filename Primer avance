// ─── Ambient Background ───────────────────────────────────────────────────────
class AmbientPainter extends CustomPainter {
  final double t;
  final Color accentColor;
  AmbientPainter(this.t, this.accentColor);

  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()..style = PaintingStyle.fill;
    final cx = size.width / 2;
    final cy = size.height / 2;
    paint.color = accentColor.withOpacity(0.06);
    canvas.drawCircle(
      Offset(cx + 80 * math.sin(t * 2 * math.pi),
          cy - 100 + 40 * math.cos(t * 2 * math.pi)),
      220, paint);
    paint.color = kPink.withOpacity(0.04);
    canvas.drawCircle(
      Offset(cx - 120 + 60 * math.cos(t * 2 * math.pi * 0.7),
          cy + 80 + 50 * math.sin(t * 2 * math.pi * 0.7)),
      180, paint);
    paint.color = kTeal.withOpacity(0.03);
    canvas.drawCircle(
      Offset(cx + 40 * math.sin(t * 2 * math.pi * 1.3),
          cy + 160 + 30 * math.cos(t * 2 * math.pi * 1.3)),
      140, paint);
  }

  @override
  bool shouldRepaint(AmbientPainter old) => old.t != t;
}

