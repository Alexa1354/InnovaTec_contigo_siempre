bool _isCrisisMessage(String text) {
  final lower = text.toLowerCase();
  final keywords = [
    'suicidio', 'suicidarme', 'suicidar', 'quitarme la vida',
    'no quiero vivir', 'quiero morir', 'matarme', 'acabar con todo',
    'ya no quiero estar aquí', 'me quiero matar',
